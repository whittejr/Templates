{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "OpenOCD Debug",
      "type": "cortex-debug",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "executable": "${command:cmake.launchTargetPath}",
      "servertype": "openocd",
      "interface": "swd",
      "runToEntryPoint": "main",
      "gdbPath": "/usr/bin/gdb-multiarch",

      "preLaunchTask": "CMake: build",
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32wbx.cfg"
      ],
      "svdFile": "${workspaceFolder}/tools/STM32WB55_CM4.svd",
      "liveWatch": {
        "enabled": true,
        "samplesPerSecond": 20
      }
    }
  ]
}