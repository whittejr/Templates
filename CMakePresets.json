{
  "version": 3,
  "configurePresets": [
    {
      "name": "base-toolchain",
      "hidden": true,
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/gcc-arm-none-eabi.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },

    {
      "name": "stm32wb55-base",
      "hidden": true,
      "inherits": "base-toolchain",
      "cacheVariables": {
        "MCU_FAMILY": "stm32wb",
        "TARGET_MCU": "STM32WB55xx"
      }
    },

    {
      "name": "wb55-debug",
      "displayName": "STM32WB55 (Debug)",
      "inherits": "stm32wb55-base",
      "binaryDir": "${sourceDir}/build/wb55-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "wb55-release",
      "displayName": "STM32WB55 (Release)",
      "inherits": "stm32wb55-base",
      "binaryDir": "${sourceDir}/build/wb55-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "wb55-debug",
      "configurePreset": "wb55-debug"
    },
    {
      "name": "wb55-release",
      "configurePreset": "wb55-release"
    }
  ]
}